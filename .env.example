# Copy this file to .env for local testing of scripts/build-data.js
# Never commit the real .env file.

# From newsdata.io (free tier: 200 requests/day, ~12h delay, allows
# non-localhost/production use -- unlike NewsAPI.org's free plan).
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Use a Bluesky APP PASSWORD (bsky.app -> Settings -> App Passwords),
# never your real account password.
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# From Google Cloud Console: create a project, enable "YouTube Data API
# v3", then create an API key (Credentials -> Create Credentials -> API
# key). No OAuth needed -- public search/comment reads only.
YOUTUBE_API_KEY=your_youtube_api_key_here